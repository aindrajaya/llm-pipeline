# Node.js API Environment Variables
# Copy this file to .env and fill in your values

# ── Server ───────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# ── Database (PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/deception_analysis

# ── Redis (BullMQ) ───────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Inference Service ────────────────────────────
INFERENCE_SERVICE_URL=http://localhost:8000

# ── Stripe ───────────────────────────────────────
# Use sk_test_... for test mode
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Metered price ID from Stripe dashboard (usage_type: metered)
STRIPE_PRICE_ID=price_your_metered_price_id

# ── Frontend ─────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Auth ─────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# ── Batch Orchestration ───────────────────────────
# Max concurrent inference slots across a batch of 100
MAX_CONCURRENT_INFERENCE=20
# Per-item inference timeout in milliseconds
ITEM_TIMEOUT_MS=30000

# ── File Uploads ──────────────────────────────────
UPLOAD_DIR=/tmp/dap-uploads
